# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MeoCare — Biến môi trường ROOT (.env)                                     ║
# ║  Copy file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.    ║
# ║  Lưu ý: các secret RIÊNG của backend (DATABASE_URL, MONGO_URI, SePay)      ║
# ║         nằm ở `backend/.env` — xem `backend/.env.example`.                 ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Chung ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://meomeocare.io.vn
# DB_PATH: đường dẫn SQLite cũ (nếu còn dùng cho seed/legacy)
DB_PATH=./backend/data/meocare.db

# ── Bảo mật ───────────────────────────────────────────────────────────────────
# BẮT BUỘC. Chuỗi ngẫu nhiên dài (>= 64 ký tự). Tạo nhanh:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=thay-bang-chuoi-ngau-nhien-that-dai

# ── Frontend (build args cho Vite) ────────────────────────────────────────────
VITE_API_URL=https://meomeocare.io.vn/api
VITE_GO2RTC_URL=https://meomeocare.io.vn/go2rtc

# ── PostgreSQL (core DB) ──────────────────────────────────────────────────────
POSTGRES_USER=meocare
POSTGRES_PASSWORD=thay-bang-mat-khau-manh
POSTGRES_DB=meocare
POSTGRES_PORT=5432

# ── MongoDB (chat) ────────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=thay-bang-mat-khau-manh
MONGO_INITDB_DATABASE=meocare_chat

# ── Mongo Express (GUI quản trị Mongo) ────────────────────────────────────────
ME_PORT=8081
ME_BASICAUTH_USERNAME=admin
ME_BASICAUTH_PASSWORD=thay-bang-mat-khau-manh

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=eyJ...token-tu-cloudflare-zero-trust

# ── Cloudflare R2 (lưu ảnh sản phẩm / hóa đơn) ────────────────────────────────
# BẮT BUỘC nếu dùng upload ảnh. Thiếu → tính năng upload sẽ lỗi.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
R2_BUCKET_NAME=meocare
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ── go2rtc (live view camera) ─────────────────────────────────────────────────
GO2RTC_API_URL=http://go2rtc:1984
GO2RTC_PUBLIC_URL=https://meomeocare.io.vn/go2rtc

# ── Edge recording (ghi tại biên — edge-agent/) ───────────────────────────────
# Ghi hình chạy ở edge-agent trên mỗi Kubuntu chi nhánh. Trung tâm MẶC ĐỊNH không
# ghi ffmpeg nữa. Đặt =true để trung tâm vẫn ghi tạm khi chi nhánh chưa có agent.
ENABLE_CENTRAL_RECORDER=false

# ── GHN (giao hàng nhanh) ─────────────────────────────────────────────────────
GHN_ENV=production
GHN_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHN_SHOP_ID=123456
GHN_FROM_DISTRICT_ID=1452

# ── Thông tin tài khoản ngân hàng (hiển thị QR thanh toán) ────────────────────
BANK_ID=MB
BANK_BIN=970422
BANK_NAME=MB Bank
BANK_ACCOUNT_NO=0123456789
BANK_ACCOUNT_NAME=CONG TY MEOCARE

# ── Chữ ký số hóa đơn ─────────────────────────────────────────────────────────
SIGN_PUBKEY_PATH=./token/public.pem
