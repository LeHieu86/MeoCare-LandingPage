generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== IDEMPOTENCY (chống request trùng phía client) ==================
// Mỗi thao tác tạo-mới quan trọng (đặt đơn, đặt lịch, xác nhận thanh toán) gửi kèm
// header "Idempotency-Key" (1 UUID sinh 1 lần cho mỗi thao tác). Nếu client double-click
// hoặc retry do timeout mạng → cùng key → server trả lại response đã lưu, KHÔNG chạy lại.
model IdempotencyKey {
  id           Int      @id @default(autoincrement())
  key          String   @unique               // giá trị header Idempotency-Key
  scope        String                          // gom theo route, vd: "POST /api/orders"
  requestHash  String                          // hash(method+url+body) — phát hiện dùng lại key với body khác
  statusCode   Int?                            // null = đang xử lý (in-progress); có giá trị = đã xong
  responseBody Json?                           // response đã cache để trả lại khi replay
  createdAt    DateTime @default(now())

  @@index([createdAt])                         // phục vụ job dọn key cũ (>24h)
  @@map("idempotency_keys")
}

// ================== STORE (CHI NHANH) ==================
model Store {
  id          Int      @id @default(autoincrement())
  name        String
  address     String?
  phone       String?
  latitude    Float?                                        // toạ độ để tìm chi nhánh gần khách nhất
  longitude   Float?
  isActive    Boolean  @default(true)  @map("is_active")
  isWarehouse Boolean  @default(false) @map("is_warehouse") // true = kho trung tâm
  isCompany   Boolean  @default(false) @map("is_company")   // true = trụ sở công ty (không phải chi nhánh phục vụ khách)
  tailscaleIp String?  @map("tailscale_ip")                 // IP/host Tailscale của chi nhánh — xem camera từ xa (rtsp://<ip>:8554/cam_<key>)
  openedAt    DateTime? @map("opened_at")                    // ngày khai trương — mốc bắt đầu cộng dồn lợi nhuận để tính hoàn vốn
  createdAt   DateTime @default(now()) @map("created_at")

  users             User[]
  rooms             Room[]
  bookings          Booking[]
  cameras           Camera[]
  orders            Order[]
  products          Product[]
  employees         Employee[]
  departments       Department[]
  inventoryItems    InventoryItem[]
  suppliers         Supplier[]
  purchaseOrders    PurchaseOrder[]
  nasConfigs        NasConfig[]
  stockRequests     StockRequest[]   @relation("BranchStockRequests")
  stockReturns      StockReturn[]    @relation("BranchStockReturns")
  otRequests        OTRequest[]
  expenses          StoreExpense[]
  capitalInvestments CapitalInvestment[]
  financeReports    FinanceReport[]
  packagingOrders   PackagingOrder[]
  catListings       CatListing[]
  catSales          CatSale[]

  @@map("stores")
}

// ================== CHI PHÍ VẬN HÀNH CHI NHÁNH ==================
model StoreExpense {
  id         Int      @id @default(autoincrement())
  store_id   Int
  month      Int                           // 1–12
  year       Int
  type        String                        // "electricity" | "water" | "rent" | "other"
  amount      Int                           // VND
  note        String?
  receipt_url String?                       // URL ảnh/PDF hóa đơn trên R2
  created_at  DateTime @default(now())
  updated_at DateTime @updatedAt

  store Store @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@index([month, year])
  @@map("store_expenses")
}

// ================== VỐN ĐẦU TƯ BAN ĐẦU CHI NHÁNH (CAPEX) ==================
// Tài sản/thiết bị/linh kiện mua MỘT LẦN khi mở chi nhánh (phòng hotel mèo, camera,
// NAS, máy tính, bàn ghế, sửa mặt bằng...). Tách hẳn khỏi StoreExpense (chi phí vận hành
// lặp hàng tháng) để tính TỔNG VỐN BỎ RA + ĐIỂM HOÀN VỐN. Không tính vào lợi nhuận tháng;
// thay vào đó lợi nhuận tích lũy "trả lại" dần số vốn này (payback).
model CapitalInvestment {
  id                 Int      @id @default(autoincrement())
  store_id           Int
  category           String                       // "room" | "camera" | "nas" | "computer" | "furniture" | "renovation" | "other"
  name               String                       // "Phòng hotel mèo", "Camera phòng mèo"...
  quantity           Int      @default(1)
  unit_price         Int                           // VND mỗi đơn vị (thành tiền = quantity * unit_price)
  useful_life_months Int?                          // tuổi thọ (tháng) để tính khấu hao tham khảo; null = không khấu hao
  purchase_date      DateTime?                     // ngày mua/đầu tư (mặc định = ngày tạo)
  note               String?
  receipt_url        String?                       // URL ảnh/PDF hóa đơn trên R2
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  store Store @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@map("capital_investments")
}

// ================== BÁO CÁO THÁNG GỬI KẾ TOÁN DUYỆT ==================
// Kế toán là trạm duyệt/thanh khoản. Mỗi tháng, từng nguồn (chi nhánh: chi phí vận hành;
// HR: lương; kho: nhập hàng) gửi 1 "báo cáo tháng" cho kế toán duyệt/từ chối.
// KHÔNG chặn số liệu P&L — đây là lớp kiểm soát chi tiền + ký xác nhận.
model FinanceReport {
  id           Int       @id @default(autoincrement())
  type         String                                  // "expense" | "salary" | "purchase"
  store_id     Int?                                    // chi nhánh (expense) / kho (purchase); null = toàn công ty (salary)
  month        Int
  year         Int
  status       String    @default("submitted")         // "submitted" | "approved" | "rejected"
  total_amount Int       @default(0)                    // snapshot tổng tiền lúc gửi
  item_count   Int       @default(0)
  note         String?                                  // ghi chú người gửi / lý do từ chối của kế toán
  submitted_by Int?
  submitted_at DateTime  @default(now())
  reviewed_by  Int?
  reviewed_at  DateTime?

  store Store? @relation(fields: [store_id], references: [id])

  @@index([type, status])
  @@index([store_id, month, year])
  @@map("finance_reports")
}

// ================== SAN PHAM ==================
model Product {
  id          Int       @id @default(autoincrement())
  store_id    Int       @default(1)
  name        String
  category    String
  image       String                          // ảnh bìa (= images[0]) — giữ cho cart/order/list cũ
  images      String[]  @default([])          // thư viện ảnh (tối đa 9), thứ tự = thứ tự hiển thị, [0] là bìa
  description String?
  sold        Int       @default(0)
  variants    Variant[]
  cartItems   CartItem[]
  reviews     Review[]
  orderItems  OrderItem[]
  store          Store          @relation(fields: [store_id], references: [id])
  inventoryItems InventoryItem[]
  @@index([store_id])
  @@index([category])          // filter theo danh mục
  @@index([sold])              // sort bestseller
  @@map("products")
}

model Review {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  orderId   Int?     @map("order_id")
  userId    Int?     @map("user_id")
  username  String   @default("Khách hàng")
  rating    Int      @default(5)
  comment   String
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id])
  @@index([productId])
  @@index([orderId])           // load reviews theo đơn hàng
  @@map("reviews")
}

model Variant {
  id         Int      @id @default(autoincrement())
  product_id Int
  name       String
  price      Int
  // ❌ XÓA: cost_price Int @default(0) @map("cost_price")
  // → Cost tracking chuyển sang InventoryItem
  product        Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  sellComponents SellProductComponent[]
  inventoryItems InventoryItem[]
  @@index([product_id])        // FK — load variants theo product
  @@map("variants")
}

// ================== KHACH HANG ==================
model Customer {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String   @unique
  address    String?
  created_at DateTime @default(now())
  orders     Order[]
  services   Service[]
  @@map("customers")
}

// ================== GIO HANG ==================
model Cart {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique 
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserCart")
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id         Int       @id @default(autoincrement())
  cartId     Int
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])

  // Chỉ lưu tên loại khách đã chọn để dễ hiển thị (VD: "Sữa dê + Thịt gà - 5 Hộp")
  variantName String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cartId])            // FK — load items của 1 giỏ hàng
  @@index([productId])         // FK — check product trong giỏ
  @@map("cart_items")
}

// ================== DON HANG ==================
model Order {
  id          Int      @id @default(autoincrement())
  invoice_no  String   @unique
  store_id    Int      @default(1)
  customer_id Int?                                   // null = khách lẻ (bán quầy không nhập khách)
  subtotal    Int
  ship_fee    Int      @default(0)
  discount    Int      @default(0)
  total       Int
  status      String   @default("pending")
  payment_method String @default("cod")
  payment_status     String    @default("unpaid")   // "unpaid" | "paid"
  payment_expired_at DateTime?                       // thời hạn QR
  note        String?
  signature   String?
  // Yêu cầu hủy đơn từ khách (chờ admin duyệt)
  cancel_requested_at    DateTime?                     // khi khách gửi yêu cầu
  cancel_request_reason  String?                       // lý do khách đưa ra
  cancel_rejected_at     DateTime?                     // khi admin từ chối
  cancel_rejected_reason String?                       // lý do admin từ chối
  // Đã hủy (admin tự hủy HOẶC admin đã duyệt yêu cầu)
  cancelled_at  DateTime?
  cancel_reason String?
  cancelled_by  String?                                // "admin" | "customer"
  // Hoàn tiền (snapshot STK + chứng từ)
  refund_bank_name    String?
  refund_bank_account String?
  refund_bank_holder  String?
  refund_bank_bin     String?
  refund_tx_ref       String?
  refund_proof_url    String?
  refunded_at         DateTime?
  created_at  DateTime @default(now())
  customer    Customer? @relation(fields: [customer_id], references: [id])
  items       OrderItem[]
  reviews     Review[]
  channel     String   @default("website")
  store       Store    @relation(fields: [store_id], references: [id])
  @@index([store_id])
  @@index([customer_id])
  @@index([status])
  @@index([payment_status])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id           Int    @id @default(autoincrement())
  order_id     Int
  product_id   Int
  variant_name String
  price        Int
  qty          Int
  subtotal     Int
  cogs_amount  Int    @default(0)  // ✅ THÊM: giá vốn thực tế lúc bán
  order        Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [product_id], references: [id])
  @@index([order_id])
  @@map("order_items")
}

// ================== PET HOTEL - PHONG ==================
model Room {
  id          String     @id
  store_id    Int        @default(1)
  name        String
  status      String     @default("active")
  camera_id   String?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  cameras     Camera[]
  services    Service[]
  bookings    Booking[]
  tokens      Token[]
  store       Store      @relation(fields: [store_id], references: [id])
  @@index([store_id])
  @@map("rooms")
}

// ================== PET HOTEL - CAMERA ==================
model Camera {
  id           Int      @id @default(autoincrement())
  store_id     Int      @default(1)
  stream_key   String   @unique @default(cuid())   // tên stream go2rtc BÍ MẬT — chống đoán cam_<id> để xem trộm
  room_id      String?                             // optional — camera độc lập, gán phòng sau
  name         String
  rtsp_url     String                              // main stream (H.265) — dùng cho ffmpeg ghi NAS
  rtsp_sub_url String?                             // sub stream (H.264) — dùng cho go2rtc live view
  recording    Boolean  @default(true)             // bật/tắt ghi ffmpeg
  disk_id      String?
  created_at DateTime @default(now())
  status     String   @default("online")
  room       Room?    @relation(fields: [room_id], references: [id], onDelete: SetNull)
  store      Store    @relation(fields: [store_id], references: [id])
  accessLogs AccessLog[]
  @@index([store_id])
  @@index([room_id])           // FK — cameras của 1 phòng
  @@map("cameras")
}

// ================== PET HOTEL - DICH VU ==================
model Service {
  id         Int      @id @default(autoincrement())
  room_id    String
  customer_id Int?
  start_time String?
  end_time   String?
  note       String?
  created_at DateTime @default(now())
  room       Room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customer_id], references: [id])
  tokens     Token[]
  @@index([room_id])           // FK — services của 1 phòng
  @@index([customer_id])       // FK — services của 1 khách
  @@map("services")
}

// ================== PET HOTEL - DAT CHO ==================
model Booking {
  id          Int      @id @default(autoincrement())
  store_id    Int      @default(1)
  cat_name    String   @default("")
  cat_breed   String?
  owner_name  String   @default("")
  owner_phone String   @default("")
  service     String   @default("day")
  room_id     String?
  check_in    String
  check_out   String
  check_in_time  String?                            // giờ khách hẹn NHẬN mèo (HH:MM), theo khung bookingHours
  check_out_time String?                            // giờ khách hẹn TRẢ mèo (HH:MM)
  status        String   @default("pending")
  cancel_reason String?
  note          String?
  contract_status   String   @default("unsigned")
  signature         String?
  digital_signature String?
  // ── Thông tin gói dịch vụ (grooming / medical) ───────────────────────────
  service_type  String   @default("boarding")  // "boarding" | "grooming" | "medical" | ...
  package_id    Int?                           // FK → ServicePackage
  package_name  String?                        // snapshot tên gói lúc đặt
  package_price Int?                           // snapshot giá lúc đặt (đồng)
  total_price   Int?                           // tổng tiền thực tế thu (nhập lúc checkout)
  created_at  DateTime @default(now())
  room        Room?           @relation(fields: [room_id], references: [id])
  package     ServicePackage? @relation(fields: [package_id], references: [id])
  store       Store           @relation(fields: [store_id], references: [id])
  @@index([store_id])
  @@index([status])                  // filter: pending / confirmed / cancelled
  @@index([room_id])                 // FK — bookings của 1 phòng
  @@index([service_type])            // filter: boarding / grooming / medical
  @@index([owner_phone])             // tìm booking theo SĐT khách
  @@index([check_in])                // filter theo ngày nhận
  @@index([status, created_at])      // composite: admin list lọc theo status + sort date
  @@map("bookings")
}

// ================== PET HOTEL - TOKEN CAMERA ==================
model Token {
  token      String   @id
  room_id    String
  service_id Int?
  expired_at DateTime?
  created_at DateTime @default(now())
  room       Room     @relation(fields: [room_id], references: [id], onDelete: Cascade)
  service    Service? @relation(fields: [service_id], references: [id])
  @@index([room_id])           // FK — tokens của 1 phòng
  @@index([expired_at])        // validation token: WHERE expired_at > NOW()
  @@map("tokens")
}

// ================== TAI KHOAN ==================
model User {
  id         Int      @id @default(autoincrement())
  store_id   Int?     @map("store_id")             // null = owner / customer (không thuộc chi nhánh cụ thể)
  username   String   @unique
  password   String
  fullName String @default("Null")
  email    String @unique @default("chua_cap_nhat@email.com")
  phone    String @default("Null")
  role       String   @default("client")   // "client" | "customer" | "employee" | "manager" | "admin" | "owner"
  created_at DateTime @default(now())
  last_login DateTime?                       // lần đăng nhập gần nhất — dùng tính thời gian ngưng hoạt động
  avatar     String?
  // Chống brute-force đăng nhập
  failed_attempts Int       @default(0)             // số lần nhập sai liên tiếp
  locked_until    DateTime?                          // khoá đăng nhập tới thời điểm này
  // Thông tin ngân hàng để hoàn tiền (tuỳ chọn)
  bank_name    String?
  bank_account String?
  bank_holder  String?
  bank_bin     String?                              // BIN code 6 chữ số dùng để gen VietQR
  accessLogs AccessLog[]
  cart      Cart?    @relation("UserCart")
  pets      Pet[]
  employee  Employee?
  store     Store?   @relation(fields: [store_id], references: [id])
  otRequestsCreated  OTRequest[] @relation("OTCreatedBy")
  otRequestsApproved OTRequest[] @relation("OTApprovedBy")
  refreshTokens      RefreshToken[]
  @@index([store_id])
  @@map("users")
}

// ================== REFRESH TOKEN (phiên đăng nhập thu hồi được) ==================
// Token ngẫu nhiên lưu DƯỚI DẠNG HASH (sha256). Mỗi lần /auth/refresh sẽ xoay vòng
// (revoke cái cũ, cấp cái mới). Logout / đổi mật khẩu → revoke để đăng xuất thiết bị.
model RefreshToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @unique               // sha256(refresh token)
  expires_at DateTime
  revoked    Boolean  @default(false)
  persistent Boolean  @default(true)          // true = "ghi nhớ" (cookie 90 ngày); false = cookie phiên (đóng trình duyệt là hết)
  user_agent String?                          // thiết bị/trình duyệt (tham khảo)
  ip         String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  @@index([user_id])
  @@index([expires_at])                       // job dọn token hết hạn
  @@map("refresh_tokens")
}

// ================== THU CUNG ==================
model Pet {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  name       String
  gender     String   @default("male")  // "male" | "female"
  breed      String   @default("")
  age        Int      @default(0)
  fromShop   Boolean  @default(false)   @map("from_shop")
  note       String?
  avatar     String?
  createdAt  DateTime @default(now())   @map("created_at")
  updatedAt  DateTime @updatedAt        @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])            // FK — pets của 1 user
  @@map("pets")
}

// ================== LOG TRUY CAP CAMERA ==================
model AccessLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  camera_id   Int
  access_time DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  camera      Camera   @relation(fields: [camera_id], references: [id], onDelete: Cascade)
  @@index([user_id])                 // FK — logs của 1 user
  @@index([camera_id, access_time])  // composite: lịch sử truy cập camera gần nhất
  @@map("access_logs")
}

// ================== NAS VIDEO SPLITTER ==================
model NasConfig {
  id               Int      @id @default(autoincrement())
  store_id         Int      @unique @default(1) @map("store_id")
  nas_root         String   @default("/mnt/nas")
  rooms            Json     @default("[]")
  segment_duration Int      @default(900)
  date_format      String   @default("%d-%m-%Y")
  output_format    String   @default(".mp4")
  codec            String   @default("copy")
  source_dir       String   @default("/home/user/videos/input")
  delete_source    Boolean  @default(false)
  run_mode         String   @default("once")
  log_file         String   @default("/tmp/recorder.log")
  watch_interval   Int      @default(30)
  updated_at       DateTime @updatedAt
  disks            Json     @default("[]")   // [{id, mount_path, label}]
  rotate_days      Int      @default(30)     // giữ bao nhiêu ngày trước khi xóa
  // ── EDGE RECORDING (ghi tại biên — mỗi chi nhánh 1 Kubuntu tự ghi) ──
  agent_token      String?  @unique          // bí mật/CN — edge agent dùng xác thực với trung tâm
  tailnet_host     String?                   // IP/MagicDNS chi nhánh trên Tailscale (live/playback từ xa)
  last_heartbeat   DateTime?                 // lần cuối agent báo về — suy ra online/offline
  runtime_status   Json?                     // {disks:{id:{...df}}, cameras:[{id,recording,pid}], ts} agent báo lên
  pending_commands Json     @default("[]")   // hàng lệnh chờ agent thực thi (reload/restart_camera...)
  store            Store    @relation(fields: [store_id], references: [id])
  @@map("nas_config")
}

// Cấu hình app dạng key-value (vd: backup_dir = ổ lưu backup admin chọn)
model AppSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt
  @@map("app_settings")
}

// Kho tri thức bot CSKH — admin tự thêm câu hỏi/đáp riêng (giờ mở cửa, chính sách
// hủy, quy định gửi mèo...). Bot dùng 2 lớp: khớp keywords (free) + neo vào grounding AI.
model CskhFaq {
  id        Int      @id @default(autoincrement())
  storeId   Int?     @map("store_id")   // null = áp dụng MỌI chi nhánh (chung); có giá trị = riêng CN đó
  question  String                       // câu hỏi/chủ đề (admin xem) — cũng đưa vào grounding AI
  answer    String                       // câu trả lời bot gửi khách
  keywords  String   @default("")        // từ khóa kích hoạt lớp luật free (phân tách dấu phẩy); trống = chỉ dùng cho AI
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)  @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@index([storeId, enabled])
  @@map("cskh_faq")
}

// ════════════════════════════════════════════════════════════════
// ERP INVENTORY SYSTEM - QUẢN LÝ TỒN KHO & NHẬP HÀNG
// ════════════════════════════════════════════════════════════════

// ──────────────────────────────────────────────
// MODEL: Nhà cung cấp
// ──────────────────────────────────────────────
model Supplier {
  id             Int             @id @default(autoincrement())
  store_id       Int             @default(1)
  name           String
  phone          String?
  address        String?
  note           String?
  isActive       Boolean         @default(true)  @map("is_active")
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt

  purchaseOrders PurchaseOrder[]
  store          Store           @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@map("suppliers")
}

// ──────────────────────────────────────────────
// MODEL: Hàng hóa tồn kho (tách riêng khỏi Variant bán)
// ──────────────────────────────────────────────
model InventoryItem {
  id              Int      @id @default(autoincrement())
  store_id        Int      @default(1)
  product_id      Int?                              // ← liên kết với Product catalog (nullable để tương thích cũ)
  variant_id      Int?                              // ← liên kết với Variant cụ thể (nullable)
  sku             String                            // VD: "PATE-CATUN-170G" — unique per store
  name            String                            // VD: "Pate Cá ngừ cua 170g"
  barcode         String?
  unit            String   @default("hộp")          // hộp, lon, thùng, kg, g, cái
  kind            String   @default("bulk")          // bulk = nguyên liệu đầu vào | retail = thành phẩm bán lẻ | both
  current_stock   Int      @default(0)              // Tồn kho hiện tại tại store này
  average_cost    Int      @default(0)              // Giá vốn bình quân
  min_stock_alert Int      @default(0)              // Cảnh báo khi tồn kho < ngưỡng này
  isActive        Boolean  @default(true)  @map("is_active")
  note            String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  purchaseItems     PurchaseOrderItem[]
  stockMovements    StockMovement[]
  sellComponents    SellProductComponent[]
  stockRequestItems StockRequestItem[]
  stockReturnItems  StockReturnItem[]  @relation("ReturnItems")
  packagingInputs   PackagingInput[]
  packagingOutputs  PackagingOutput[]
  store             Store    @relation(fields: [store_id], references: [id])
  product           Product? @relation(fields: [product_id], references: [id])
  variant           Variant? @relation(fields: [variant_id], references: [id])

  @@unique([store_id, sku])    // cùng SKU ở store khác nhau là ok
  @@index([store_id])
  @@index([product_id])
  @@index([variant_id])
  @@index([isActive])
  @@map("inventory_items")
}

// ──────────────────────────────────────────────
// MODEL: Phiếu nhập hàng
// ──────────────────────────────────────────────
model PurchaseOrder {
  id           Int      @id @default(autoincrement())
  store_id     Int      @default(1)
  po_number    String   @unique                     // VD: PN260503-001
  supplier_id  Int
  total_cost   Int      @default(0)
  status       String   @default("draft")           // "draft" | "confirmed" | "cancelled"
  note         String?
  confirmed_at DateTime?                            // ✅ THÊM: Thời điểm xác nhận nhập kho
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  supplier     Supplier          @relation(fields: [supplier_id], references: [id])
  items        PurchaseOrderItem[]
  store        Store             @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@index([supplier_id])
  @@index([status])
  @@map("purchase_orders")
}

// ──────────────────────────────────────────────
// MODEL: Chi tiết phiếu nhập (theo InventoryItem, không phải Variant)
// ──────────────────────────────────────────────
model PurchaseOrderItem {
  id                Int           @id @default(autoincrement())
  po_id             Int
  inventory_item_id Int                          // ✅ SỬA: nhập theo hàng hóa thực tế
  unit_cost         Int                          // ✅ SỬA: Giá nhập thực tế lần này
  qty               Int                          // Số lượng nhập
  subtotal          Int                          // unit_cost × qty

  po            PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventory_item_id], references: [id])

  @@index([po_id])                   // FK — items của 1 phiếu nhập
  @@index([inventory_item_id])       // FK — lịch sử nhập của 1 hàng hóa
  @@map("purchase_order_items")
}

// ──────────────────────────────────────────────
// MODEL: Mapping Combo → Tồn kho
// VD: Variant "Combo 5 hộp" = 5 × InventoryItem "Pate cá ngừ 170g"
// ──────────────────────────────────────────────
model SellProductComponent {
  id                Int           @id @default(autoincrement())
  variant_id        Int                          // Variant bán (combo)
  inventory_item_id Int                          // Hàng hóa thực trong kho
  qty               Int                          // Số lượng cần để tạo 1 combo

  variant       Variant       @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventory_item_id], references: [id])

  @@unique([variant_id, inventory_item_id])     // 1 variant không map 2 lần cùng 1 item
  @@map("sell_product_components")
}

// ──────────────────────────────────────────────
// MODEL: Lịch sử biến động tồn kho (audit log)
// ──────────────────────────────────────────────
model StockMovement {
  id                Int      @id @default(autoincrement())
  inventory_item_id Int
  type              String                       // purchase | sale | adjustment | return | damaged
  qty_change        Int                          // + nhập / - xuất
  qty_before        Int                          // Tồn kho trước khi thay đổi
  qty_after         Int                          // Tồn kho sau khi thay đổi
  unit_cost         Int      @default(0)         // Giá vốn tại thời điểm biến động
  reference_type    String?                      // "purchase_order" | "order" | "manual"
  reference_id      Int?                         // ID của phiếu nhập hoặc đơn hàng
  note              String?
  created_at        DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventory_item_id], references: [id])

  @@index([inventory_item_id])
  @@index([type])
  @@index([reference_type, reference_id])
  @@map("stock_movements")
}

// ════════════════════════════════════════════════════════════════
// HR MODULE - QUẢN LÝ NHÂN VIÊN & CHẤM CÔNG
// ════════════════════════════════════════════════════════════════

// ── Hồ sơ nhân viên (liên kết với User) ──────────────────────
model Department {
  id          Int      @id @default(autoincrement())
  store_id    Int
  name        String                              // "Chăm sóc thú cưng", "Bán hàng", "Kho"
  code        String?                             // "CARE", "SALES"
  head_id     Int?     @map("head_id")            // employee.id trưởng bộ phận
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  store      Store      @relation(fields: [store_id], references: [id])
  positions  Position[]
  employees  Employee[] @relation("EmpDepartment")

  @@index([store_id])
  @@map("departments")
}

model Position {
  id            Int      @id @default(autoincrement())
  department_id Int
  name          String                              // "Nhân viên chăm sóc", "Trưởng ca"
  level         Int      @default(1)               // 1=nhân viên, 2=trưởng ca, 3=trưởng bộ phận
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  department Department @relation(fields: [department_id], references: [id])
  employees  Employee[]  @relation("EmpPosition")

  @@index([department_id])
  @@map("positions")
}

model Employee {
  id            Int      @id @default(autoincrement())
  store_id      Int      @default(1)
  userId        Int      @unique                    @map("user_id")
  employeeCode  String   @unique                    @map("employee_code")  // NV001
  // Cũ (giữ cho tương thích)
  department    String   @default("general")
  position      String   @default("Nhân viên")
  // Mới: FK tới Department/Position
  department_id Int?
  position_id   Int?
  // Loại hợp đồng
  employmentType String  @default("full-time")      @map("employment_type") // "full-time" | "part-time"
  contractType   String  @default("permanent")      @map("contract_type")   // "permanent" | "fixed-term" | "probation"
  // Ca mặc định (full-time: 1 ca cố định T2-T7)
  defaultShiftId Int?    @map("default_shift_id")
  // Thông tin cá nhân mở rộng
  cccd          String?                             // Căn cước công dân
  birthDate     DateTime?                           @map("birth_date")
  gender        String    @default("male")          // "male" | "female" | "other"
  address       String?
  // Hợp đồng
  startDate     DateTime @default(now())            @map("start_date")
  endDate       DateTime?                           @map("end_date")
  // Lương
  salaryType    String   @default("monthly")        @map("salary_type")   // "hourly" | "monthly"
  baseSalary    Int      @default(0)                @map("base_salary")
  status        String   @default("active")        // "active" | "inactive" | "terminated"
  note          String?
  // Thông tin ngân hàng
  bankName        String?  @map("bank_name")
  bankAccount     String?  @map("bank_account")
  bankAccountName String?  @map("bank_account_name")
  bankBin         String?  @map("bank_bin")
  createdAt     DateTime @default(now())            @map("created_at")
  updatedAt     DateTime @updatedAt                 @map("updated_at")

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  dept             Department?        @relation("EmpDepartment", fields: [department_id], references: [id])
  pos              Position?          @relation("EmpPosition", fields: [position_id], references: [id])
  defaultShift     Shift?             @relation("EmpDefaultShift", fields: [defaultShiftId], references: [id])
  shiftAssignments ShiftAssignment[]
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]
  salaryRecords    SalaryRecord[]
  otRequests       OTRequest[]
  documents        EmployeeDocument[]
  store            Store              @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@index([status])
  @@index([department])
  @@index([employmentType])
  @@map("employees")
}

// ── Hồ sơ & tài liệu nhân viên ────────────────────────────────
model EmployeeDocument {
  id           Int      @id @default(autoincrement())
  employeeId   Int                      @map("employee_id")
  type         String   @default("other") // "contract" | "id_card" | "certificate" | "degree" | "other"
  name         String                   // tên hiển thị
  fileName     String                   @map("file_name")   // tên file lưu trên disk
  filePath     String                   @map("file_path")   // đường dẫn tương đối trên server
  fileSize     Int?                     @map("file_size")   // bytes
  mimeType     String?                  @map("mime_type")
  note         String?
  uploadedById Int?                     @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
}

// ── Số ngày phép còn lại theo loại ────────────────────────────
model LeaveBalance {
  id           Int    @id @default(autoincrement())
  employee_id  Int
  year         Int
  leave_type   String  // "annual" | "sick" | "unpaid" | "maternity" | "other"
  total_days   Float   @default(0)  @map("total_days")
  used_days    Float   @default(0)  @map("used_days")
  // HR điều chỉnh thủ công
  note         String?              // lý do HR điều chỉnh
  adjusted_by  Int?    @map("adjusted_by")  // userId HR đã điều chỉnh
  updated_at   DateTime @updatedAt  @map("updated_at")

  employee Employee @relation(fields: [employee_id], references: [id])

  @@unique([employee_id, year, leave_type])
  @@index([employee_id])
  @@map("leave_balances")
}

// ── Ca làm việc (template) ─────────────────────────────────────
model Shift {
  id               Int      @id @default(autoincrement())
  name             String                                // "Ca sáng", "Ca chiều", "Ca tối"
  startTime        String                  @map("start_time")       // "08:00"
  endTime          String                  @map("end_time")         // "16:00"
  maxSlots         Int      @default(10)   @map("max_slots")
  isActive         Boolean  @default(true) @map("is_active")
  // ── Quy định nghỉ trưa (áp dụng cho full-time) ────────────
  lunchBreakStart  String?                 @map("lunch_break_start") // "11:00" — null = không có nghỉ trưa
  lunchBreakEnd    String?                 @map("lunch_break_end")   // "13:00"
  // ── Biên độ chấm công (phút) ──────────────────────────────
  lateGraceMinutes  Int     @default(10)   @map("late_grace_minutes")   // trễ vào ca tối đa X phút
  earlyGraceMinutes Int     @default(10)   @map("early_grace_minutes")  // về sớm tối đa X phút
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt      @map("updated_at")

  assignments      ShiftAssignment[]
  defaultForEmps   Employee[]        @relation("EmpDefaultShift")

  @@map("shifts")
}

// ── Phân ca / Đăng ký ca ──────────────────────────────────────
model ShiftAssignment {
  id          Int      @id @default(autoincrement())
  shiftId     Int                      @map("shift_id")
  employeeId  Int                      @map("employee_id")
  date        DateTime                 // ngày cụ thể
  status      String   @default("scheduled") // "scheduled" | "completed" | "absent" | "cancelled"
  registeredBy String  @default("manager")   @map("registered_by") // "employee" | "manager" | "admin"
  createdById Int?                     @map("created_by_id")  // userId admin/manager tạo
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  shift      Shift    @relation(fields: [shiftId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])
  attendance Attendance?

  @@unique([shiftId, employeeId, date])
  @@index([date])
  @@index([employeeId])
  @@index([status])            // filter theo trạng thái ca
  @@map("shift_assignments")
}

// ── Chấm công ─────────────────────────────────────────────────
model Attendance {
  id                Int      @id @default(autoincrement())
  employeeId        Int                      @map("employee_id")
  shiftAssignmentId Int?     @unique         @map("shift_assignment_id")
  date              DateTime
  checkIn           DateTime?                @map("check_in")
  checkOut          DateTime?                @map("check_out")
  workHours         Float    @default(0)     @map("work_hours")
  overtimeHours     Float    @default(0)     @map("overtime_hours")
  status            String   @default("present") // "present" | "absent" | "late" | "early_leave" | "on_leave"
  note              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt      @map("updated_at")

  employee        Employee         @relation(fields: [employeeId], references: [id])
  shiftAssignment ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id])

  @@index([employeeId, date])  // composite: chấm công của NV trong khoảng ngày
  @@index([date])
  @@index([status])            // filter: late / absent / present
  @@map("attendances")
}

// ── Đơn xin nghỉ phép ─────────────────────────────────────────
model LeaveRequest {
  id           Int      @id @default(autoincrement())
  employeeId   Int                        @map("employee_id")
  // "annual"|"sick"|"unpaid"|"maternity"|"wedding"|"paternity"|"other"
  leaveType    String                     @map("leave_type")
  startDate    DateTime                   @map("start_date")
  endDate      DateTime                   @map("end_date")
  totalDays    Float                      @map("total_days")
  reason       String
  // Workflow 2 tầng: pending → manager_approved → hr_approved (= approved) / rejected
  status            String   @default("pending")
  // Tầng 1: Manager duyệt
  managerStatus     String?  @map("manager_status")      // "approved" | "rejected" | null
  managerApprovedBy Int?     @map("manager_approved_by")
  managerApprovedAt DateTime? @map("manager_approved_at")
  managerNote       String?  @map("manager_note")
  // Tầng 2: HR duyệt
  hrStatus          String?  @map("hr_status")           // "approved" | "rejected" | null
  hrApprovedBy      Int?     @map("hr_approved_by")
  hrApprovedAt      DateTime? @map("hr_approved_at")
  hrNote            String?  @map("hr_note")
  // Legacy
  approvedById Int?                       @map("approved_by_id")
  approvedAt   DateTime?                  @map("approved_at")
  rejectReason String?                    @map("reject_reason")
  // Nghỉ không lương theo giờ (chỉ dùng khi leaveType = "unpaid")
  startTime    String?                    @map("start_time")  // "08:00"
  endTime      String?                    @map("end_time")    // "12:00"
  createdAt    DateTime @default(now())   @map("created_at")
  updatedAt    DateTime @updatedAt        @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

// ── Bảng lương hàng tháng ─────────────────────────────────────
model SalaryRecord {
  id              Int      @id @default(autoincrement())
  employeeId      Int                         @map("employee_id")
  periodType      String   @default("monthly") @map("period_type")   // "monthly" | "weekly"
  month           Int                         // 1-12
  year            Int
  week            Int?                        // 1-53 (chỉ dùng cho part-time weekly)
  weekStart       DateTime?                   @map("week_start")     // ngày đầu tuần
  weekEnd         DateTime?                   @map("week_end")       // ngày cuối tuần
  salaryType      String   @default("monthly") @map("salary_type")
  baseSalary      Int                         @map("base_salary")
  standardDays    Float    @default(26)        @map("standard_days")
  workedDays      Float    @default(0)         @map("worked_days")
  totalWorkHours  Float    @default(0)         @map("total_work_hours")
  overtimeHours   Float    @default(0)         @map("overtime_hours")
  overtimePay     Int      @default(0)         @map("overtime_pay")
  bonus           Int      @default(0)
  allowance       Int      @default(0)
  deduction       Int      @default(0)
  unpaidLeaveDays Float    @default(0)         @map("unpaid_leave_days")
  netSalary       Int      @default(0)         @map("net_salary")
  status          String   @default("draft")  // "draft" | "confirmed" | "paid"
  note            String?
  paidAt          DateTime?                    @map("paid_at")
  createdAt       DateTime @default(now())     @map("created_at")
  updatedAt       DateTime @updatedAt          @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year, week]) // week null = monthly
  @@index([employeeId])
  @@index([year, month])
  @@index([periodType])
  @@index([status])
  @@map("salary_records")
}

// ── Phiếu OT ──────────────────────────────────────────────────────────────────
model OTRequest {
  id             Int      @id @default(autoincrement())
  employeeId     Int                          @map("employee_id")
  storeId        Int                          @map("store_id")
  createdById    Int                          @map("created_by_id")  // userId manager tạo
  date           DateTime                     // ngày OT
  hours          Float                        // số giờ OT
  reason         String                       // lý do
  otType         String   @default("planned") @map("ot_type")       // "planned" | "emergency"
  status         String   @default("pending")                        // "pending" | "approved" | "rejected"
  approvedById   Int?                         @map("approved_by_id") // userId HR duyệt
  approvedAt     DateTime?                    @map("approved_at")
  rejectedReason String?                      @map("rejected_reason")
  // Kỳ lương áp dụng (tự động tính từ date + deadline)
  payMonth       Int                          @map("pay_month")
  payYear        Int                          @map("pay_year")
  payWeek        Int?                         @map("pay_week")       // chỉ dùng nếu part-time
  createdAt      DateTime @default(now())     @map("created_at")
  updatedAt      DateTime @updatedAt          @map("updated_at")

  employee    Employee @relation(fields: [employeeId], references: [id])
  store       Store    @relation(fields: [storeId],    references: [id])
  createdBy   User     @relation("OTCreatedBy",  fields: [createdById],  references: [id])
  approvedBy  User?    @relation("OTApprovedBy", fields: [approvedById], references: [id])

  @@index([employeeId])
  @@index([storeId])
  @@index([status])
  @@index([payMonth, payYear])
  @@map("ot_requests")
}

// ================== LOAI DICH VU (admin-managed) ==================
model ServiceTypeDef {
  id              Int      @id @default(autoincrement())
  key             String   @unique  // đã có UNIQUE index tự động
  icon            String   @default("🐾")
  name            String
  subtitle        String   @default("")
  description     String   @default("")
  priceFrom       String   @default("Liên hệ")   @map("price_from")
  pricePerDay     Int      @default(0)            @map("price_per_day")
  priceMultiDay   Int      @default(0)            @map("price_multi_day")
  color           String   @default("linear-gradient(135deg, #C7B8EA 0%, #9F8FD9 100%)")
  accent          String   @default("#9F8FD9")
  bgAccent        String   @default("linear-gradient(135deg, #C7B8EA 0%, #9F8FD9 100%)") @map("bg_accent")
  available       Boolean  @default(false)
  useTimeProgress Boolean  @default(false)        @map("use_time_progress")
  // "per_day" = tính theo ngày (boarding)
  // "package"  = chọn gói cố định (grooming)
  // "procedure" = chọn ca/thủ thuật (medical)
  pricingType     String   @default("per_day")    @map("pricing_type")
  stages          Json     @default("[]")
  // Khung giờ khách được chọn để NHẬN/TRẢ (chỉ dùng cho boarding/per_day).
  // Cấu trúc: { enabled, slotMinutes, days: { "0".."6": { open, start, end } } } (0=CN..6=T7).
  // Admin chỉnh trong app Flutter → không cần sửa code khi đổi giờ.
  bookingHours    Json     @default("{\"enabled\":true,\"slotMinutes\":30,\"days\":{\"0\":{\"open\":true,\"start\":\"08:00\",\"end\":\"21:00\"},\"1\":{\"open\":true,\"start\":\"18:00\",\"end\":\"22:00\"},\"2\":{\"open\":true,\"start\":\"18:00\",\"end\":\"22:00\"},\"3\":{\"open\":true,\"start\":\"18:00\",\"end\":\"22:00\"},\"4\":{\"open\":true,\"start\":\"18:00\",\"end\":\"22:00\"},\"5\":{\"open\":true,\"start\":\"18:00\",\"end\":\"22:00\"},\"6\":{\"open\":true,\"start\":\"18:00\",\"end\":\"22:00\"}}}") @map("booking_hours")
  sortOrder       Int      @default(0)            @map("sort_order")
  createdAt       DateTime @default(now())        @map("created_at")
  updatedAt       DateTime @updatedAt             @map("updated_at")

  packages        ServicePackage[]

  @@index([available])         // public API: chỉ lấy dịch vụ available=true
  @@map("service_type_defs")
}

// ================== GOI DICH VU (grooming / medical) ==================
model ServicePackage {
  id            Int      @id @default(autoincrement())
  serviceTypeId Int                         @map("service_type_id")
  name          String                      // "Gói Basic", "Triệt sản"
  description   String   @default("")
  price         Int      @default(0)
  duration      String?                     // "2-3 giờ", "30 phút" (tuỳ chọn)
  includes      Json     @default("[]")     // ["Tắm", "Sấy lông", "Cắt móng"]
  isPopular     Boolean  @default(false)    @map("is_popular")
  isActive      Boolean  @default(true)     @map("is_active")
  sortOrder     Int      @default(0)        @map("sort_order")
  createdAt     DateTime @default(now())    @map("created_at")
  updatedAt     DateTime @updatedAt         @map("updated_at")

  serviceType   ServiceTypeDef @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([serviceTypeId])     // FK — gói của 1 loại dịch vụ (query phổ biến nhất)
  @@index([isActive])          // filter gói đang hoạt động
  @@map("service_packages")
}

// ================== PHIẾU NHẬP KHO (CHI NHÁNH → KHO TRUNG TÂM) ==================
model StockRequest {
  id           Int      @id @default(autoincrement())
  request_code String   @unique                    // VD: "PN-20260529-001"
  from_store_id Int                                // Chi nhánh gửi yêu cầu
  status       String   @default("pending")        // pending | confirmed | shipping | delivered | cancelled
  note         String?
  confirmed_at DateTime?
  shipped_at   DateTime?
  delivered_at DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  items      StockRequestItem[]
  from_store Store             @relation("BranchStockRequests", fields: [from_store_id], references: [id])

  @@index([from_store_id])
  @@index([status])
  @@map("stock_requests")
}

model StockRequestItem {
  id                Int           @id @default(autoincrement())
  request_id        Int
  inventory_item_id Int                            // InventoryItem tại KHO TRUNG TÂM
  quantity          Int                            // Số lượng yêu cầu
  fulfilled_qty     Int           @default(0)      // Số lượng thực giao (có thể ít hơn nếu hết hàng)
  note              String?

  request       StockRequest  @relation(fields: [request_id], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventory_item_id], references: [id])

  @@index([request_id])
  @@index([inventory_item_id])
  @@map("stock_request_items")
}

// ── Phiếu Hoàn Hàng: Chi nhánh hoàn hàng NGƯỢC về Kho Tổng (đảo chiều StockRequest) ──
model StockReturn {
  id            Int       @id @default(autoincrement())
  return_code   String    @unique                   // VD: "HT-20260616-001"
  from_store_id Int                                 // Chi nhánh hoàn hàng
  status        String    @default("pending")       // pending | received | cancelled
  note          String?
  received_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  items      StockReturnItem[]
  from_store Store             @relation("BranchStockReturns", fields: [from_store_id], references: [id])

  @@index([from_store_id])
  @@index([status])
  @@map("stock_returns")
}

model StockReturnItem {
  id                Int           @id @default(autoincrement())
  return_id         Int
  inventory_item_id Int                            // InventoryItem tại CHI NHÁNH (hàng đang hoàn)
  quantity          Int
  note              String?

  stockReturn   StockReturn   @relation(fields: [return_id], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation("ReturnItems", fields: [inventory_item_id], references: [id])

  @@index([return_id])
  @@index([inventory_item_id])
  @@map("stock_return_items")
}

// ================== PHIẾU ĐÓNG GÓI / TÁI CHẾ ==================
// Nhập bulk → phân loại → combo (5 lon, 10 lon, 1kg, 2kg...)
model PackagingOrder {
  id           Int       @id @default(autoincrement())
  code         String    @unique                   // PKG-20260604-001
  store_id     Int                                 // luôn là Kho Tổng
  status       String    @default("draft")         // draft | completed | cancelled
  note         String?
  total_input_cost Int   @default(0)               // snapshot tổng chi phí đầu vào
  remainder_qty    Int   @default(0)               // số đơn vị dư sau khi đóng gói
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  inputs   PackagingInput[]
  outputs  PackagingOutput[]
  store    Store @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@index([status])
  @@map("packaging_orders")
}

model PackagingInput {
  id                 Int @id @default(autoincrement())
  packaging_order_id Int
  inventory_item_id  Int
  quantity           Int              // số đơn vị nhập (vd: 2 thùng)
  units_per_input    Int @default(1)  // số đơn vị nhỏ mỗi item (vd: 24 lon/thùng)
  // total_base_units = quantity × units_per_input

  order         PackagingOrder @relation(fields: [packaging_order_id], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem  @relation(fields: [inventory_item_id], references: [id])

  @@index([packaging_order_id])
  @@map("packaging_inputs")
}

model PackagingOutput {
  id                 Int @id @default(autoincrement())
  packaging_order_id Int
  inventory_item_id  Int
  quantity           Int              // số combo/bịch tạo ra (vd: 4 gói 5-lon)
  units_per_pack     Int @default(1)  // số đơn vị nhỏ mỗi combo (vd: 5 lon)
  unit_cost          Int @default(0)  // giá vốn tự tính (snapshot lúc complete)
  // total_base_units_used = quantity × units_per_pack

  order         PackagingOrder @relation(fields: [packaging_order_id], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem  @relation(fields: [inventory_item_id], references: [id])

  @@index([packaging_order_id])
  @@map("packaging_outputs")
}

// ════════════════════════════════════════════════════════════════
// BÁN MÈO (CAT CATALOG) — Phase 1: catalog + web showcase
// ════════════════════════════════════════════════════════════════
// Mèo là CÁ THỂ DUY NHẤT (không phải hàng tồn đếm số lượng như InventoryItem).
// Mỗi con = 1 dòng CatListing, có vòng đời available → sold. "Lai catalog chung":
// quản lý tập trung nhưng mỗi con gắn 1 chi nhánh (store_id) đang giữ; web hiện tất cả.
model CatListing {
  id          Int       @id @default(autoincrement())
  code        String    @unique                       // VD: MEO-260620-001
  store_id    Int                                      // chi nhánh đang giữ mèo
  name        String
  breed       String    @default("")                  // giống (Anh lông ngắn, Munchkin...)
  color       String    @default("")
  gender      String    @default("male")              // "male" | "female"
  birth_date  DateTime?                                // ngày sinh — FE tự tính tuổi (chính xác hơn nhập tay)
  weight      Float?                                   // kg (tuỳ chọn)
  price       Int       @default(0)                   // giá bán (đồng)
  cost        Int       @default(0)                   // giá vốn nhập — CHỈ admin/kế toán, không lộ ra web
  source      String?                                 // nguồn nhập (trại/người bán)
  description String?
  image       String    @default("")                  // ảnh bìa (= images[0]) — giữ tương thích list cũ
  images      String[]  @default([])                  // thư viện ảnh (tối đa 9)
  vaccinated  Boolean   @default(false)               // đã tiêm phòng cơ bản
  dewormed    Boolean   @default(false)               // đã tẩy giun
  status      String    @default("available")         // "available" | "sold" | "unavailable"
  published   Boolean   @default(true)                // có hiện trên web showcase không
  sold_at     DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  store         Store             @relation(fields: [store_id], references: [id])
  healthRecords CatHealthRecord[]
  sale          CatSale?

  @@index([store_id])
  @@index([status])
  @@index([published])
  @@index([breed])
  @@map("cat_listings")
}

// Hồ sơ sức khỏe từng con — vừa là điểm bán (khách yên tâm), vừa là cơ sở BẢO HÀNH ở Phase 3.
model CatHealthRecord {
  id         Int       @id @default(autoincrement())
  cat_id     Int
  type       String    @default("vaccine")            // "vaccine" | "deworm" | "checkup" | "other"
  name       String                                   // "Mũi 1 - 4 bệnh", "Tẩy giun Drontal"
  date       DateTime
  vet        String?                                  // bác sĩ / phòng khám
  next_due   DateTime?                                // hẹn mũi/lần kế tiếp
  note       String?
  created_at DateTime  @default(now())

  cat CatListing @relation(fields: [cat_id], references: [id], onDelete: Cascade)

  @@index([cat_id])
  @@map("cat_health_records")
}

// ── Phase 2: BÁN MÈO TẠI QUẦY (POS) — SỔ DOANH THU RIÊNG ──
// Mỗi giao dịch bán 1 con (cat_id UNIQUE → bán 1 lần). KHÔNG sinh Order → doanh thu mèo
// tách biệt khỏi P&L sản phẩm (theo quyết định "sổ doanh thu riêng"). Danh tính khách theo
// buyer_phone (cầu nối ưu đãi Phase 3). Bán xong: chốt mèo sold + tạo Pet(fromShop) cho user
// khớp SĐT. warranty_until = mốc bảo hành sức khỏe (Phase 3 áp voucher khám).
model CatSale {
  id              Int      @id @default(autoincrement())
  code            String   @unique                  // BMEO-YYMMDD-NNN
  cat_id          Int      @unique                   // 1 con bán đúng 1 lần
  store_id        Int                                // chi nhánh bán
  sold_by         Int?                               // userId nhân viên bán (tham khảo)
  buyer_name      String   @default("")
  buyer_phone     String   @default("")
  buyer_address   String?
  price           Int                                // giá bán thực thu
  cost            Int      @default(0)               // giá vốn snapshot lúc bán → tính lãi
  payment_method  String   @default("cash")          // "cash" | "bank"
  payment_status  String   @default("paid")          // "paid" | "unpaid"
  contract_signed Boolean  @default(false)           // khách đã ký hợp đồng giấy
  signature       String?                            // chữ ký số (để dành — chưa dùng Phase 2)
  warranty_until  DateTime?                           // bảo hành sức khỏe đến ngày
  status          String   @default("completed")     // "completed" | "cancelled"
  note            String?
  cancelled_at    DateTime?
  cancel_reason   String?
  sold_at         DateTime @default(now())
  created_at      DateTime @default(now())

  cat   CatListing @relation(fields: [cat_id], references: [id])
  store Store      @relation(fields: [store_id], references: [id])

  @@index([store_id])
  @@index([sold_at])
  @@index([status])
  @@index([buyer_phone])
  @@map("cat_sales")
}

// ════════════════════════════════════════════════════════════════
// PHASE 3: VÍ ƯU ĐÃI KHÁCH MUA MÈO (gắn theo SĐT — cầu nối User/Customer/Pet)
// ════════════════════════════════════════════════════════════════
// Khi 1 CatSale hoàn tất → tự phát (theo config cat_perk_config trong AppSetting):
//   • CustomerMembership: giảm % đồ ăn "ongoing" trong N tháng (1 dòng / SĐT).
//   • BenefitVoucher: ưu đãi DÙNG 1 LẦN (gửi mèo free đêm / spa free / giảm tiêm / khám bảo hành).
// KHÔNG FK tới Customer/User — khóa theo phone để áp được cả đơn POS lẫn booking.
model CustomerMembership {
  id                Int       @id @default(autoincrement())
  phone             String    @unique
  name              String    @default("")
  tier              String    @default("cat-owner")
  food_discount_pct Int       @default(0)              // % giảm đồ ăn/phụ kiện
  discount_until    DateTime?                           // hết hiệu lực giảm đồ ăn
  points            Int       @default(0)               // điểm tích lũy
  source_sale_id    Int?                                // CatSale phát sinh membership
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@map("customer_memberships")
}

model BenefitVoucher {
  id             Int       @id @default(autoincrement())
  phone          String
  type           String                                // health_check | boarding_free_nights | grooming_free | vaccine_discount
  title          String                                // nhãn hiển thị cho nhân viên/khách
  value          Json      @default("{}")              // {nights:2} | {pct:30} | {}
  status         String    @default("active")          // active | used | expired
  valid_until    DateTime?
  source_sale_id Int?
  used_at        DateTime?
  used_ref       String?                               // "order:123" | "booking:45" | ghi chú khi redeem
  created_at     DateTime  @default(now())

  @@index([phone, status])
  @@index([source_sale_id])
  @@map("benefit_vouchers")
}

// ════════════════════════════════════════════════════════════════
// TÓM TẮT THAY ĐỔI
// ════════════════════════════════════════════════════════════════
// ✅ Product: XÓA purchaseItems relation
// ✅ Variant: XÓA cost_price field, THÊM sellComponents relation
// ✅ OrderItem: THÊM cogs_amount field
// ✅ Order: channel field đã có sẵn
// ✅ Supplier: THÊM is_active field
// ✅ PurchaseOrder: THÊM confirmed_at field
// ✅ PurchaseOrderItem: SỬA HOÀN TOÀN để link với InventoryItem
// ✅ THÊM MỚI: InventoryItem, SellProductComponent, StockMovement
