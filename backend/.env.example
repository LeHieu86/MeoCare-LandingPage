# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MeoCare — Biến môi trường BACKEND (backend/.env)                          ║
# ║  Copy thành `backend/.env` rồi điền giá trị thật. KHÔNG commit `.env`.     ║
# ║  server.js nạp file này TRƯỚC, rồi tới ../.env (root).                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── PostgreSQL — Prisma datasource ────────────────────────────────────────────
# BẮT BUỘC. Prisma migrate VÀ Prisma Client lúc runtime đều cần biến này.
# Trong Docker, host là tên service `postgres-core`.
DATABASE_URL=postgresql://meocare:matkhau@postgres-core:5432/meocare?schema=public

# ── MongoDB — chat ────────────────────────────────────────────────────────────
# BẮT BUỘC nếu dùng chat. Trong Docker, host là `mongo-chat`.
MONGO_URI=mongodb://root:matkhau@mongo-chat:27017/meocare_chat?authSource=admin

# ── Xác thực / JWT ────────────────────────────────────────────────────────────
# JWT_SECRET: BẮT BUỘC. Chuỗi dài ngẫu nhiên để ký access token.
# ⚠️ Ở production thiếu biến này → server TỪ CHỐI khởi động (fail-closed).
#    Sinh nhanh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=thay_bang_chuoi_ngau_nhien_dai
# NODE_ENV=production  → bật Secure cookie + bắt buộc JWT_SECRET
NODE_ENV=production
# Hạn access token (ngắn). VD: 15m / 30m / 1h. Mặc định 30m.
ACCESS_TOKEN_TTL=30m
# Hạn refresh token (ngày) — "giữ đăng nhập" lâu nhưng thu hồi được. Mặc định 90.
REFRESH_TOKEN_TTL_DAYS=90

# ── Thông báo cho chủ tiệm (Telegram) ─────────────────────────────────────────
# Báo realtime khi có đặt lịch/đơn/chat mới + nhắc nhận-trả mèo. Thiếu → tự bỏ qua.
# Cách lấy: nhắn @BotFather tạo bot → lấy TOKEN; nhắn bot 1 câu rồi mở
#   https://api.telegram.org/bot<TOKEN>/getUpdates để lấy chat id ("chat":{"id":...}).
# Nhiều người nhận: ngăn cách bằng dấu phẩy.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Tailscale — chấm xanh/xám "máy chi nhánh còn online?" ở trang Chi nhánh ───
# Backend hỏi Tailscale API xem máy có IP trong ô "IP Tailscale" của chi nhánh còn
# kết nối không. Thiếu cấu hình → tắt hẳn, trang Chi nhánh vẫn chạy như cũ.
#
# Cách 1 (KHUYÊN DÙNG) — OAuth client, KHÔNG hết hạn:
#   https://login.tailscale.com/admin/settings/trust-credentials
#   → Credential → OAuth → tick READ cho nhóm Devices (devices:core) → Generate credential.
#   Secret CHỈ hiện 1 lần, đóng trang là mất → copy vào đây ngay.
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
#
# Cách 2 — access token tạo tay (nhanh hơn nhưng HẾT HẠN tối đa 90 ngày, tới hạn là
# chấm tắt ngúm cho tới khi bạn thay token mới):
#   https://login.tailscale.com/admin/settings/keys → Generate access token.
# TAILSCALE_API_KEY=tskey-api-xxxxxxxxxxxx
#
# '-' = tailnet mặc định của credential. Hầu như không cần đổi.
TAILSCALE_TAILNET=-
# Cache danh sách thiết bị trong RAM (ms). Độ trễ chấm live mà người dùng THẤY =
# biến này + chu kỳ app tự nạp lại (15s, trong stores_provider.dart) — chúng CỘNG
# dồn, không phải lấy số lớn hơn. 15000 → chậm nhất ~30s. Hạ nữa thì tốn lần gọi
# API Tailscale mà mắt thường gần như không phân biệt được.
TAILSCALE_CACHE_TTL_MS=15000
# Gọi Tailscale API hỏng liên tục quá ngần này (ms) → chấm chuyển "Không rõ" (xám).
# Cố tình KHÔNG giữ trạng thái cũ mãi: thà nói "không biết" còn hơn hiện xanh "Online"
# bằng số liệu từ đời nào trong khi máy đã rớt. Phải lớn hơn TTL vài lần để chịu được
# blip mạng ngắn (vd: bật/tắt Tailscale trên host làm Docker mất mạng vài giây).
TAILSCALE_STALE_MAX_MS=60000

# ── SePay — cổng thanh toán chuyển khoản ──────────────────────────────────────
# SEPAY_API_KEY: gọi API SePay (tra cứu giao dịch).
SEPAY_API_KEY=xxxxxxxxxxxxxxxxxxxx

# SEPAY_WEBHOOK_SECRET: BẮT BUỘC để xác thực HMAC webhook.
# ⚠️ Thiếu biến này → backend TỪ CHỐI mọi webhook (fail-closed) để tránh
#    bị giả mạo giao dịch "đã thanh toán". Lấy secret trong dashboard SePay.
SEPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Bot CSKH (chat khách hàng) — LAI: Lớp LUẬT (miễn phí) + AI dự phòng ───────
# AI_CSKH_ENABLED = công tắc tổng của bot:
#  - =true, KHÔNG có ANTHROPIC_API_KEY → chỉ chạy LỚP LUẬT (FAQ giá/dịch vụ/địa
#    chỉ/SĐT, $0). Câu lạ → để nhân viên (luồng người như cũ).
#  - =true, CÓ ANTHROPIC_API_KEY → LAI: luật trả câu phổ biến (free); câu lạ mới
#    gọi AI (tiết kiệm); AI tự chuyển nhân viên + Telegram khi ngoài phạm vi.
#  - =false → tắt hẳn bot, chat hoạt động như cũ.
AI_CSKH_ENABLED=false
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Model: claude-sonnet-4-6 (cân bằng, khuyên dùng) | claude-haiku-4-5 (rẻ) | claude-opus-4-8 (mạnh)
AI_CSKH_MODEL=claude-sonnet-4-6
# Chống spam đốt tiền AI (đếm trong RAM):
#  - AI_MIN_GAP_SEC: tối thiểu N giây giữa 2 lần AI trả lời TRONG 1 hội thoại
#  - AI_MAX_PER_CONV_HOUR: tối đa lần AI trả lời/giờ cho 1 hội thoại
#  - AI_MAX_PER_DAY: TRẦN tuyệt đối số lần gọi AI/ngày TOÀN hệ thống (backstop chi phí)
AI_MIN_GAP_SEC=8
AI_MAX_PER_CONV_HOUR=15
AI_MAX_PER_DAY=1000
