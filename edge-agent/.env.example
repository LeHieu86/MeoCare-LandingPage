# ── Edge Agent config (mỗi chi nhánh 1 file .env riêng) ──

# URL trung tâm (Phase 1–2 dùng HTTPS công khai/Cloudflare; Phase 3+ có thể dùng tailnet)
CENTRAL_URL=https://api.meocare.example.com

# Token bí mật của CHI NHÁNH này — phải khớp NasConfig.agent_token ở trung tâm.
# Tạo bằng: trung tâm gọi POST /api/admin/nas/agent-token (trả token), hoặc tự sinh
#   openssl rand -hex 32   rồi lưu vào NasConfig.agent_token của đúng store.
AGENT_TOKEN=

# Chu kỳ kéo config + reconcile (giây). 60s là hợp lý.
POLL_INTERVAL=60
